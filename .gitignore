# ============================================================
# SECURITY — KEYS & SECRETS (never commit these)
# ============================================================
.env
.env.*
!.env.example
*.env
secrets.json
secrets.yaml
secrets.yml
config/secrets.*
**/secrets/**

# API keys, tokens, credentials
*.key
*.pem
*.p12
*.pfx
*.cer
*.crt
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
*.asc

# ============================================================
# PYTHON
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so

# Virtual environments
.venv/
venv/
env/
ENV/
.env/
.python-version
